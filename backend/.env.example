# ============================================================================
# BASEERA 360 - Backend Environment Configuration
# ============================================================================

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Database
DATABASE_URL=postgresql://baseera_app:secure_password@localhost:5432/baseera_360
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT=30000

# JWT & Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d
BCRYPT_ROUNDS=10

# File Storage (AWS S3 or Azure Blob)
STORAGE_TYPE=local  # local, s3, azure
STORAGE_BUCKET=baseera-360-uploads
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret

# CDN Configuration
CDN_URL=https://cdn.baseera.ae
THUMBNAIL_SIZE=200x200

# Email Service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_FROM_EMAIL=noreply@baseera.ae

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Third-party Services
SENTRY_DSN=
MIXPANEL_TOKEN=

# CORS
CORS_ORIGIN=http://localhost:3001,https://app.baseera.ae

# Feature Flags
ENABLE_THERMAL_ANALYSIS=true
ENABLE_3D_VIEWER=true
ENABLE_360_PANORAMA=true
ENABLE_GIS=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# API Documentation
API_DOCS_ENABLED=true
API_DOCS_URL=/api/docs
